#!/bin/sh
# OrbitDeck AppImage launcher. Defaults to the GUI; "term" launches OrbitTerm.
HERE="$(dirname "$(readlink -f "$0")")"
export PYTHONPATH="$HERE/usr/lib/python3/dist-packages:$PYTHONPATH"
if [ "$1" = "term" ]; then
    shift
    exec python3 -m orbitterm "$@"
fi
exec python3 -m orbitdeck.gui.app "$@"
